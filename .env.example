# Supabase
NEXT_PUBLIC_SUPABASE_URL=cccccc
NEXT_PUBLIC_SUPABASE_ANON_KEY=c.cccc
SUPABASE_SERVICE_ROLE_KEY=\ccccc

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Nebius AI (Image Generation)
NEBIUS_API_KEY=your_nebius_api_key
NEBIUS_API_URL=https://api.studio.nebius.ai/v1/

# Haiper AI (Video Generation)
HAIPER_API_KEY=your_haiper_api_key
HAIPER_API_URL=https://api.haiper.ai/v1/

# Bhashini AI (Hindi TTS)
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_USER_ID=your_bhashini_user_id

# Google Cloud TTS
GOOGLE_CLOUD_TTS_API_KEY=your_google_tts_api_key

# Cloudflare R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=bharatshort-videos
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Upstash Redis (Queue System)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_USER_CREDITS=100

# Razorpay Payments
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=razorpay_secret
RAZORPAY_WEBHOOK_SECRET=razorpay_webhook_secret

# Geo-IP Lookup
GEOIP_LOOKUP_URL=https://ipapi.co/{ip}/json/
GENERATION_EXECUTION_MODE=inline
WORKER_SECRET=change_me_for_worker_endpoint
WORKER_MAX_JOBS_PER_TICK=5
WORKER_MAX_DURATION_MS=45000
WORKER_MAX_ATTEMPTS=3
REFUND_ON_TERMINAL_FAILURE=true
PAYMENT_RECONCILE_CRON_ENABLED=true
PAYMENT_RECONCILE_LIMIT=200
PAYMENT_RECON_ALERT_WEBHOOK_URL=
